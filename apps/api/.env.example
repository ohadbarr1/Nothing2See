# Server
PORT=3001
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Cache (Upstash Redis) — leave blank to use in-memory fallback
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# External APIs
TMDB_API_KEY=your_tmdb_api_key_here
OMDB_API_KEY=your_omdb_api_key_here
RAPIDAPI_KEY=your_rapidapi_key_here

# CORS — set to your production frontend URL in production (comma-separated for multiple origins)
# In development this is unused (all origins allowed). In production a missing or blank value
# will cause all cross-origin requests to be blocked, so always set this before deploying.
ALLOWED_ORIGINS=http://localhost:5173

# Auth (Phase 2)
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret
# Separate secret used to sign/verify refresh tokens (must differ from JWT_SECRET)
# Generate: openssl rand -hex 64
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret
# Generate a strong random secret for cookie signing
# Generate: openssl rand -hex 64
COOKIE_SECRET=change-me-to-another-long-random-secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Frontend URL (used for OAuth redirect after login)
FRONTEND_URL=http://localhost:5173

# Email (nodemailer) — used for watchlist availability notifications
EMAIL_FROM=no-reply@nothing2see.app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_smtp_app_password
